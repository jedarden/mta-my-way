# MTA My Way - Production Environment Configuration
# Copy this file to .env and fill in the values for production deployment

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port number for the HTTP server (default: 3001)
PORT=3001

# Environment: development or production
NODE_ENV=production

# Test mode for E2E tests (do NOT enable in production)
# TEST_MODE=true

# =============================================================================
# SECURITY - Host Header Protection (REQUIRED for production)
# =============================================================================
# Comma-separated list of allowed hostnames for this server
# Example: mta-my-way.example.com,www.mta-my-way.example.com
# SECURITY WARNING: Leaving this empty allows ANY hostname, which exposes
# the application to host header injection attacks. In production mode,
# the server will fail to start if ALLOWED_HOSTS is not set.
ALLOWED_HOSTS=

# =============================================================================
# SECURITY - Password Pepper (Recommended)
# =============================================================================
# A server-wide secret combined with passwords before hashing
# Generate with: openssl rand -hex 32
# This provides defense-in-depth: even if the database is compromised,
# attackers cannot crack passwords without the pepper.
# Leave empty to disable pepper (less secure, but passwords remain hashed)
PASSWORD_PEPPER=

# =============================================================================
# WEB PUSH NOTIFICATIONS (VAPID) - Required for push notification features
# =============================================================================
# VAPID keys for web push notifications
# Generate with: npx web-push generate-vapid-keys
# SECURITY WARNING: These keys are required for push notifications to work.
# The public key is shared with the client; the private key stays on server.
# Never commit the private key to version control.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Contact URI for VAPID (mailto: or https://)
# This should be a valid contact email or URL for your application
VAPID_SUBJECT=mailto:mta-my-way@example.com

# =============================================================================
# DATABASE - Push Subscriptions
# =============================================================================
# Path to SQLite database for push subscriptions (default: packages/server/data/subscriptions.db)
PUSH_DB_PATH=

# =============================================================================
# EMAIL - Password Reset Delivery
# =============================================================================
# Provider: ses | smtp | sendgrid | console (default: console)
EMAIL_PROVIDER=console

# Sender identity (used by all providers)
EMAIL_FROM=noreply@mtamyway.com
EMAIL_FROM_NAME=MTA My Way
# EMAIL_REPLY_TO=support@mtamyway.com

# Base URL for password reset links (default: http://localhost:5173)
# RESET_BASE_URL=https://mta-my-way.example.com

# --- AWS SES (EMAIL_PROVIDER=ses) ---
# Credentials are read from standard AWS env vars; AWS_REGION defaults to us-east-1.
# The SES sender address must be verified in your AWS account.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- SMTP (EMAIL_PROVIDER=smtp) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587      # 587 for STARTTLS, 465 for SSL
# SMTP_USER=
# SMTP_PASSWORD=

# --- SendGrid (EMAIL_PROVIDER=sendgrid) ---
# SENDGRID_API_KEY=

# =============================================================================
# LOGGING
# =============================================================================
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
