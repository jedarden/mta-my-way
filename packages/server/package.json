{
  "name": "@mta-my-way/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b && mkdir -p dist/proto && cp src/proto/compiled.js dist/proto/compiled.js",
    "typecheck": "tsc --noEmit",
    "compile-proto": "pbjs -t static-module -w es6 -o src/proto/compiled.js src/proto/gtfs-realtime.proto src/proto/nyct-subway.proto && node scripts/fix-esm-import.mjs && pbts -o src/proto/compiled.d.ts src/proto/compiled.js",
    "dev": "node --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "process-gtfs": "node scripts/process-gtfs.mjs",
    "process-gtfs:verbose": "node scripts/process-gtfs.mjs --verbose",
    "migrate": "node scripts/migrate.mjs",
    "migrate:status": "node scripts/migrate.mjs status",
    "migrate:up": "node scripts/migrate.mjs up",
    "migrate:down": "node scripts/migrate.mjs down",
    "migrate:rollback": "node scripts/migrate.mjs rollback",
    "migrate:create": "node scripts/migrate.mjs create",
    "migrate:validate": "node scripts/migrate.mjs validate",
    "migrate:backup": "node scripts/migrate.mjs backup",
    "migrate:restore": "node scripts/migrate.mjs restore",
    "migrate:backups": "node scripts/migrate.mjs backups",
    "migrate:cleanup": "node scripts/migrate.mjs cleanup"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1045.0",
    "@hono/node-server": "1.19.11",
    "@mta-my-way/shared": "*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.2",
    "@opentelemetry/instrumentation": "^0.57.2",
    "@opentelemetry/instrumentation-http": "^0.57.2",
    "@opentelemetry/resources": "^1.29.0",
    "@opentelemetry/sdk-trace-base": "^1.29.0",
    "@opentelemetry/sdk-trace-node": "^1.29.0",
    "@opentelemetry/semantic-conventions": "^1.29.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.8.0",
    "csv-parse": "^6.2.1",
    "hono": "^4.12.8",
    "nodemailer": "^8.0.7",
    "protobufjs": "^7.5.4",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/argon2": "^0.15.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.3",
    "@vitest/coverage-v8": "^3.2.4",
    "protobufjs-cli": "^2.0.0"
  }
}
