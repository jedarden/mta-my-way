{
  "name": "@mta-my-way/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b && mkdir -p dist/proto && cp src/proto/compiled.js dist/proto/compiled.js",
    "typecheck": "tsc --noEmit",
    "compile-proto": "pbjs -t static-module -w es6 -o src/proto/compiled.js src/proto/gtfs-realtime.proto src/proto/nyct-subway.proto && node scripts/fix-esm-import.mjs && pbts -o src/proto/compiled.d.ts src/proto/compiled.js",
    "dev": "node --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "process-gtfs": "node scripts/process-gtfs.mjs",
    "process-gtfs:verbose": "node scripts/process-gtfs.mjs --verbose"
  },
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "@mta-my-way/shared": "*",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.12.8",
    "protobufjs": "^7.5.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/web-push": "^3.6.3",
    "csv-parse": "^6.2.1",
    "protobufjs-cli": "^2.0.0"
  }
}
